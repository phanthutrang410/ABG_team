# G02 / H27 — API base for the frontend fetch client (lib/api.ts).
# Copy to .env.local (gitignored) and adjust; not committed with real values.

# Local backend: keep browser calls same-origin and let Next proxy to Uvicorn.
NEXT_PUBLIC_API_BASE=
BACKEND_URL=http://localhost:8000

# Vercel / HTTPS production (H27): leave NEXT_PUBLIC_API_BASE empty (same-origin)
# and set BACKEND_URL to the Live FastAPI origin. next.config.js rewrites proxy
# /auth, /review-cases, /cases, /config, /fairness, /health, /advisor-handoff-drafts,
# /weekly-reports, /weekly-briefings.
# On Vercel, unset NEXT_PUBLIC_API_BASE defaults to "" and BACKEND_URL defaults
# to the D4b Live API when VERCEL=1.
# NEXT_PUBLIC_API_BASE=
# BACKEND_URL=http://52.74.255.88:8000

# Do NOT set NEXT_PUBLIC_API_BASE=http://… on an HTTPS frontend (mixed content).

# Optional local-only Notify fixture. Copy this line to .env.local when testing;
# do not enable it in a production deployment.
# NEXT_PUBLIC_ADVISOR_HANDOFF_DRAFTS_URL=/__local__/advisor-handoff-drafts.json

# Local/dev-only: advisor UI fixtures + offline demo login fallback (G07).
# Never required for production builds; ignored when NODE_ENV=production.
# NEXT_PUBLIC_ADVISOR_LOCAL_DEMO=1
