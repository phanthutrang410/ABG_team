# Backend
DATABASE_URL=postgresql+psycopg://silentshield:silentshield@localhost:5432/silentshield
SCORING_MODEL_VERSION=m10-reality460-logreg-1.0
# Optional operator override. Empty uses the committed, hash-verified artifact.
SCORING_MODEL_ARTIFACT=
# Optional: override default data/approved/semester/domain_package.json (raw V59 or alt package)
# SILENT_SHIELD_SEMESTER_SOURCE_PATH=C:\path\to\v59-empty-program-students.json
# local|dev|test allow seed POST /cases; production|live disable (override with CASES_SEED_CREATE)
APP_ENV=local
# CASES_SEED_CREATE=true
# Demo seed accounts (quanly/gvcn/demo) — canonical password for local + Live seed CLI
AUTH_SEED_PASSWORD=demo123
CASES_TRUSTED_ACTOR=acct:demo
CASES_TRUSTED_ACTOR_KIND=human
# Decision #27 — enable H08 join of v59-empty grades + mvp-attendance (same student_ref)
# LINKED_NAMESPACE_APPROVAL=approval:mvp-linked-v59-att:v1:acfb7d80dc3a
# Leave empty to keep Mode B (semester without attendance join)
LINKED_NAMESPACE_APPROVAL=approval:mvp-linked-v59-att:v1:acfb7d80dc3a
# OpenAI target (Decision #22 / H29) — runtime reads these; pin model (no "latest").
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1-mini
# Legacy FPT (H23–H26 historical). Inactive after H29 — not used by get_text_model.
# Historical guide: docs/04-engineering/01-fpt-ai-api.md
FPT_API_KEY=
FPT_BASE_URL=https://mkp-api.fptcloud.com
FPT_MODEL=Qwen/Qwen3-32B

# Agent
MAX_CONCURRENT_AGENT_RUNS=3
AGENT_RUN_TIMEOUT_SECONDS=120

# CORS — comma-separated extra browser origins (localhost:3000 always allowed)
# CORS_ORIGINS=http://52.74.255.88:3000
# Optional if browser ever calls API directly from Vercel (H27 uses same-origin proxy — not required):
# CORS_ORIGINS=http://52.74.255.88:3000,https://abg-team.vercel.app

# Frontend (Next.js)
# Local: browser → API directly. Vercel H27: NEXT_PUBLIC_API_BASE empty + BACKEND_URL for rewrites.
NEXT_PUBLIC_API_BASE=http://localhost:8000
BACKEND_URL=http://localhost:8000
# Local/dev only: advisor UI fixtures in localStorage. Always ignored when NODE_ENV=production.
# Do not set on Vercel Production — default path is fail-closed unavailable until G07 scoped API.
# NEXT_PUBLIC_ADVISOR_LOCAL_DEMO=1
# Vercel Production (Dashboard env; names only — values may differ):
# NEXT_PUBLIC_API_BASE=
# BACKEND_URL=http://52.74.255.88:8000

# MCP (set as Windows User env vars so Cursor GUI sees them — do not commit real values)
# GITHUB_TOKEN=ghp_...          # https://github.com/settings/tokens (repo + read:org)
# AWS_PROFILE=default
# AWS_REGION=ap-southeast-1
